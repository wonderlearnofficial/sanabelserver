# ─────────────────────────────────────────────────────────────
# Sanabel server environment. Copy to `.env` and fill real values.
# Never commit the real `.env` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
SERVER_PORT=5000
# PORT is injected by the host (Railway, etc.) in production.

# Database
DB_DRIVER=mysql            # or "mariadb"
MYSQL_DB_HOST=localhost
MYSQL_DB_PORT=3306
MYSQL_DB_NAME=snablelahssan
MYSQL_DB_USER=root
MYSQL_DB_PASS=

# Auth / JWT
JWT_SECRET=                # required — access-token signing secret
REFRESH_TOKEN_SECRET=      # recommended — separate refresh-token secret
ACCESS_TOKEN_TTL=30m       # access-token lifetime (default 30m)
REFRESH_TOKEN_TTL=7d       # refresh-token lifetime (default 7d)

# Admin bootstrap
ADMIN_EMAIL=
ADMIN_PASSWORD=

# CORS — comma-separated list of trusted web origins (production).
# Capacitor/localhost origins are always allowed; dev reflects any origin.
CORS_ORIGINS=https://sanabel.wonderlearn.net

# Security limits (all optional; sensible defaults applied if unset)
JSON_BODY_LIMIT=1mb        # max JSON request body
AUTH_RATE_LIMIT=50         # max auth-endpoint requests / 15 min / IP
MAX_UPLOAD_BYTES=5242880   # max Excel/CSV upload size in bytes (5 MB)
OTP_MAX_ATTEMPTS=5         # wrong OTPs before temporary lockout
OTP_LOCK_MINUTES=15        # lockout duration after too many wrong OTPs

# Bulk import
DEFAULT_IMPORT_PASSWORD=changeme123   # onboarding password for imported users

# Email (Resend preferred; SMTP fallback)
RESEND_API_KEY=
EMAIL_USER=
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Misc
BASE_URL=
LOG_LEVEL=info
